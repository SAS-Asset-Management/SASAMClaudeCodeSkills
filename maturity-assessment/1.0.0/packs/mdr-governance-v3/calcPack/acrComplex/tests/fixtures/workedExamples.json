        {"element_id": "e05", "inspected": true, "defects": []},
        {"element_id": "e06", "inspected": true, "defects": [{"DCR_raw": 2, "CC": 4, "RMC": 3}]},
        {"element_id": "e07", "inspected": true, "defects": [{"DCR_raw": 2, "CC": 4, "RMC": 3}]},
        {"element_id": "e08", "inspected": true, "defects": [{"DCR_raw": 3, "CC": 4, "RMC": 3}]},
        {"element_id": "e09", "inspected": true, "defects": [{"DCR_raw": 3, "CC": 4, "RMC": 3}]},
        {"element_id": "e10", "inspected": true, "defects": [{"DCR_raw": 4, "CC": 4, "RMC": 3}]}
      ],
      "expected_ACR": 4,
